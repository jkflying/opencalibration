digraph {
    "INITIAL_PROCESSING\ninitial_processing()" -> "MESH_REFINEMENT\nmesh_refinement()" [label="NEXT\nnext_loaded_ids.size() == 0 && next_linked_ids.size() == 0", style="solid", weight=1]
